# ── Contact form delivery ────────────────────────────────────────────────
# The contact form posts to /api/contact, which emails the lead via Resend
# (see src/app/api/contact/route.ts). Get an API key at resend.com/api-keys
# and verify the domain CONTACT_FROM_EMAIL sends from. If any of these three
# are unset, submissions are only logged server-side, never emailed — the
# site still runs with zero configuration in local dev.
RESEND_API_KEY=
CONTACT_TO_EMAIL=summitstudioagency@gmail.com
CONTACT_FROM_EMAIL=website@summitstudioagency.com

# ── Site ─────────────────────────────────────────────────────────────────
# Canonical production URL (used for sitemap, robots, and OpenGraph).
NEXT_PUBLIC_SITE_URL=https://summitstudioagency.com
